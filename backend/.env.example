# OpenAI-compatible provider used by the current backend code
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=qwen3.5-plus
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_QA_ENABLE_THINKING=false
OPENAI_QA_TIMEOUT=30
OPENAI_QA_MAX_TOKENS=600
OPENAI_ASSETS_ENABLE_THINKING=false
OPENAI_ASSETS_TIMEOUT=35
OPENAI_ASSETS_MAX_TOKENS=1200

# RAGFlow retrieval
RAGFLOW_BASE_URL=http://192.168.2.224
RAGFLOW_API_KEY=
RAGFLOW_DATASET_IDS=
RAGFLOW_TIMEOUT=15
RAGFLOW_PAGE_SIZE=8
RAGFLOW_TOP_K=8
RAGFLOW_SIMILARITY_THRESHOLD=0.2
RAGFLOW_VECTOR_SIMILARITY_WEIGHT=0.3
RAGFLOW_KEYWORD_SEARCH=true

# Anthropic-compatible settings for external tools or future SDK usage
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=qwen3.5-plus
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# Doubao image generation for animation assets
DOUBAO_IMAGE_API_KEY=
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
DOUBAO_IMAGE_SIZE=1920x1920
DOUBAO_IMAGE_CACHE_DIR=./generated_assets/images
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000
